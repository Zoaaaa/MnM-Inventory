{
  "name": "mnm-inventory-backend",
  "version": "1.0.0",
  "description": "Backend API for MnM Speedcube Shop Inventory",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:setup": "node src/db/setup.js",
    "db:seed": "node src/db/seed.js",
    "db:reset": "node src/db/setup.js && node src/db/seed.js",
    "db:migrate:featured": "node src/db/migrate-featured.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "slugify": "^1.6.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
